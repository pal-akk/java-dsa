static final int L=26;
    public static boolean checkPangram(String s) {
        boolean[] vis= new boolean[L];
        for(int i=0;i<s.length();i++){
            char c= s.charAt(i);
            if(c>='A' && c<='Z'){
                vis[c-'A']= true;
            }
            else if(c>='a' && c<='z'){
                vis[c-'a']=true;
            }
        }
        for(int i=0;i<L;i++){
            if(vis[i]==false) return false;
        }
        return true;
    }
